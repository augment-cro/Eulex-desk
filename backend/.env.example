PORT=3001
FRONTEND_URL=http://localhost:3000

# ── Legal source document proxy (/legal-docs) ────────────────────────────
# Upstream EULEX document APIs for the right-side citation panel (Phase 2).
# EU is public and has a built-in default; HR/FR Cloud Run are private
# (--no-allow-unauthenticated), so the backend mints a Google ID token for
# the service URL — its runtime service account needs roles/run.invoker on
# the HR/FR services. _TOKEN is an optional static-bearer override.
# Unset ⇒ the corresponding legal-source scope is disabled.
# EULEX_EU_API_BASE=https://<your-eu-legal-api>.example.com
# EULEX_HR_API_BASE=https://<your-hr-legal-api>.example.com
# EULEX_FR_API_BASE=https://<your-fr-legal-api>.example.com
# EULEX_EU_API_TOKEN=
# EULEX_HR_API_TOKEN=
# EULEX_FR_API_TOKEN=
# Externally-reachable backend URL. Used to build the OAuth callback URL for
# MCP connectors. Defaults to http://localhost:${PORT} when unset.
BACKEND_PUBLIC_URL=http://localhost:3001

# ── Database (Cloud SQL) ─────────────────────────────────────────────────
# Production: set CLOUD_SQL_CONNECTION_NAME + DB_IAM_USER for IAM auth via
# the Cloud SQL Node.js Connector (no password needed).
CLOUD_SQL_CONNECTION_NAME=your-project:your-region:your-db-instance
DB_IAM_USER=your-service-account@your-project.iam
DB_NAME=mike

# Development: set DATABASE_URL (overrides Cloud SQL Connector).
# Use Cloud SQL Auth Proxy: cloud-sql-proxy <CLOUD_SQL_CONNECTION_NAME> --port 5433
DATABASE_URL=postgresql://mike_app:your-local-password@127.0.0.1:5433/mike

# ── Auth ─────────────────────────────────────────────────────────────────
# Legacy WordPress-OAuth (Ultimate Membership Pro) HS256 JWT secret. Still
# accepted by requireAuth so existing logins keep working during the
# Supabase transition (dual-token). Remove once fully cut over to Supabase.
EULEX_MCP_JWT_SECRET=your-jwt-signing-secret

# Optional dedicated secret for HMAC-signing download tokens and MCP OAuth
# state tokens. If unset, both fall back to EULEX_MCP_JWT_SECRET above. There
# is NO insecure literal fallback — if neither is set, signing fails closed.
# DOWNLOAD_SIGNING_SECRET=

# Optional dedicated 64-char hex (32-byte) key for AES-256-GCM encryption of
# stored integration API keys (integration_accounts). If unset, the key is
# derived from EULEX_MCP_JWT_SECRET. Do NOT change once tokens are encrypted —
# rotating it makes existing ciphertext undecryptable. Fails closed if neither
# this nor EULEX_MCP_JWT_SECRET is set.
# API_KEY_ENCRYPTION_KEY=

# Supabase Auth (identity only — data stays in Cloud SQL). When set, the
# auth middleware ALSO accepts Supabase access tokens, verifying them via
# the project JWKS (asymmetric ES256). Leave UNSET to disable the Supabase
# path entirely (middleware behaves exactly as the WP-only version).
# No trailing slash.
SUPABASE_URL=https://<project-ref>.supabase.co
# Secret (service_role) key — ONLY needed by the user-migration script
# (backend/scripts/migrate-users-to-supabase.ts), never for token
# verification. Keep out of the frontend.
# SUPABASE_SECRET_KEY=sb_secret_...

# ── Built-in MCP servers (mike/mcp.json) ─────────────────────────────────
# Optional absolute path to a JSON file declaring server-side MCP connectors
# that should be loaded on every chat request without appearing in the
# connectors UI. See <repo>/mike/README.md for the format. When unset the
# loader searches ./mike/mcp.json, ../mike/mcp.json and /app/mike/mcp.json.
# MIKE_MCP_CONFIG=/secrets/mike-mcp.json

# ── Object Storage (Google Cloud Storage) ───────────────────────────────
# On Cloud Run the default service account is used automatically via ADC —
# no credentials needed when the SA has the Storage Object Admin role.
GCS_BUCKET_NAME=your-gcs-bucket-name

# ── AI / LLM API Keys ───────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key
OPENROUTER_API_KEY=your-openrouter-key

# ── Web Search providers (backend/src/lib/search) ────────────────────────
# The `web_search` LLM tool and the /search route call whichever of these
# providers has a key set. Auto-pick priority is: tavily → exa → parallel
# → you. Set at least one; setting multiple is fine — the LLM (or caller)
# can request a specific one via `provider: "exa" | "parallel" | ...`.
#
# Tavily — general-purpose, AI-optimised summaries.
#   Get a key: https://app.tavily.com (free tier available)
TAVILY_API_KEY=your-tavily-key
# Exa — neural/semantic search, best for technical / long-form content.
#   Get a key: https://dashboard.exa.ai/api-keys
EXA_API_KEY=your-exa-key
# Parallel — agentic LLM-objective search; multi-query under the hood.
#   Get a key: https://platform.parallel.ai
PARALLEL_API_KEY=your-parallel-key
# You.com — unified web + news, best for current events.
#   Get a key: https://api.you.com
YOU_API_KEY=your-you-key

# ── Email (chat share invites — routes/chatShares.ts) ────────────────────
# Provider selector. "brevo" (default) ships email through @getbrevo/brevo;
# "noop" logs to console only and is the right pick for local dev / CI.
EMAIL_PROVIDER=brevo
BREVO_API_KEY=your-brevo-api-key
EMAIL_FROM_ADDR=noreply@your-domain.example
EMAIL_FROM_NAME=Eulex Desk
# Number of days a share-invite link stays valid. Default 30.
CHAT_SHARE_TTL_DAYS=30

# ── vLLM (OpenAI-compatible endpoint) ────────────────────────────────────
VLLM_BASE_URL=https://your-vllm-endpoint.com/v1
VLLM_API_KEY=your-vllm-api-key
VLLM_MAIN_MODEL=your-main-model-name
VLLM_LIGHT_MODEL=your-light-model-name

