# ── Supabase Auth (identity only — data stays in Cloud SQL on GCP) ───────
# URL + publishable key are PUBLIC and ship in the client bundle by design.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_<your-key>
# Secret (service_role) key — server-only, NEVER expose to the browser.
# Used only by server-side helpers / migration tooling.
SUPABASE_SECRET_KEY=your-supabase-service-role-key

NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
# Set to 1 to use SuperDoc instead of docx-preview for DOCX viewing
NEXT_PUBLIC_USE_SUPERDOC=1

# AGPL §13 source offer — public mirror URL for the in-app "Source code"
# link on the login page. Empty/unset = link hidden.
NEXT_PUBLIC_SOURCE_URL=https://github.com/augment-cro/Eulex-desk

# Optional contexts service (open contract — see contracts/) — base URL the
# browser calls directly for context management. Empty = contexts UI hidden.
NEXT_PUBLIC_CONTEXTS_URL=
